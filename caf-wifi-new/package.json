{
  "name": "caf-wifi-new",
  "version": "3.5.0",
  "private": true,
  "description": "CAF-WiFi Enterprise Analyzer — desktop WiFi scanner",
  "author": {
    "name": "Hany Bkhite",
    "email": "hanybkhite@gmail.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently \"next dev -p 3579\" \"wait-on http://127.0.0.1:3579 && electron .\"",
    "electron:build": "next build && electron-builder",
    "dist": "npm run electron:build",
    "dist:win": "next build && electron-builder --win",
    "dist:mac": "next build && electron-builder --mac",
    "dist:linux": "next build && electron-builder --linux"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.caf.wifi-analyzer",
    "productName": "CAF-WiFi Analyzer",
    "directories": { "output": "dist" },
    "files": [
      "electron/**/*",
      "app/**/*",
      ".next/**/*",
      "public/**/*",
      "next.config.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "public/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "public/icon.png",
      "category": "Network",
      "maintainer": "Hany Bkhite <hanybkhite@gmail.com>"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
